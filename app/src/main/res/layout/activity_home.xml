<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F4FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        app:cardCornerRadius="19dp"
                        app:cardBackgroundColor="#F07030"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#FFFFFF"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="@string/app_name"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name_lowercase"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpgrade"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/upgrade"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#F07030"
                    app:cornerRadius="18dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ivAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#DDDDDD"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#999999"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/avatar"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/tabSachNoi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingEnd="28dp"
                    android:paddingStart="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/audiobooks"
                        android:textColor="#E84B3A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingTop="12dp"
                        android:paddingBottom="10dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="#E84B3A"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabEbook"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingEnd="28dp"
                    android:paddingStart="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ebooks"
                        android:textColor="#888888"
                        android:textSize="15sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="13dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="#00000000"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabTomTat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/book_summaries"
                        android:textColor="#888888"
                        android:textSize="15sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="13dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="#00000000"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E8E6F5"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="135dp"
                            android:layout_height="200dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="4dp"
                            android:layout_marginEnd="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#F5E6C8"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/book_end_procrastination"
                                    android:textColor="#C47A2A"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:gravity="center"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/author_darius_foroux"
                                    android:textColor="#8B6040"
                                    android:textSize="11sp"
                                    android:layout_marginTop="8dp"
                                    android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/featuredBook"
                            android:layout_width="185dp"
                            android:layout_height="265dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="8dp"
                            android:layout_marginEnd="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="#E8620A"
                                    android:orientation="vertical"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="MARK MANSON"
                                        android:textColor="#FFDDAA"
                                        android:textSize="11sp"
                                        android:letterSpacing="0.12"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/featured_book_title"
                                        android:textColor="#FFFFFF"
                                        android:textSize="17sp"
                                        android:textStyle="bold"
                                        android:lineSpacingMultiplier="1.1"
                                        android:layout_marginTop="6dp"/>
                                </LinearLayout>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="46dp"
                                    android:layout_height="46dp"
                                    android:layout_gravity="bottom|end"
                                    android:layout_margin="10dp"
                                    app:cardCornerRadius="23dp"
                                    app:cardBackgroundColor="#FFFFFF"
                                    app:cardElevation="4dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:src="@android:drawable/ic_media_play"
                                        app:tint="#E84B3A"
                                        android:padding="10dp"
                                        android:scaleType="fitCenter"
                                        android:contentDescription="@string/play"/>
                                </com.google.android.material.card.MaterialCardView>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="34dp"
                                    android:layout_gravity="bottom"
                                    android:background="#CC111111"
                                    android:gravity="center_vertical"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/best_seller"
                                        android:textColor="#FFFFFF"
                                        android:textSize="11sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>

                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="135dp"
                            android:layout_height="200dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#1A1A2E"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/book_think_and_grow_rich"
                                    android:textColor="#F5C518"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:gravity="center"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/author_napoleon_hill"
                                    android:textColor="#AAAAAA"
                                    android:textSize="11sp"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recommended_for_you"
                    android:textColor="#1A1A2E"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recommended_subtitle"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="148dp"
                            app:cardCornerRadius="8dp" app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="#D4A870" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/book_thu_cho_em" android:textColor="#5C3010"
                                    android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/book_thu_cho_em_title" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:maxLines="2" android:layout_marginTop="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/author_hoang_nam_tien" android:textColor="#999999" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="148dp"
                            app:cardCornerRadius="8dp" app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="#1A1A2E" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/book_think_and_grow_rich" android:textColor="#F5C518"
                                    android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/book_think_and_grow_rich_title" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:maxLines="2" android:layout_marginTop="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/author_napoleon_hill" android:textColor="#999999" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="148dp"
                            app:cardCornerRadius="8dp" app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="#2D7A4F" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/book_khong_gia_dinh" android:textColor="#CCFFDD"
                                    android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/book_khong_gia_dinh_title" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:maxLines="2" android:layout_marginTop="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/author_hector_malot" android:textColor="#999999" android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="18dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="148dp"
                            app:cardCornerRadius="8dp" app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="#E8620A" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/book_nghe_thuat_tinh_te" android:textColor="#FFFFFF"
                                    android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/book_nghe_thuat_tinh_te_title" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:maxLines="2" android:layout_marginTop="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/author_mark_manson" android:textColor="#999999" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="148dp"
                            app:cardCornerRadius="8dp" app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="#F5E0C0" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/book_end_procrastination" android:textColor="#8B5010"
                                    android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/book_end_procrastination_title" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:maxLines="2" android:layout_marginTop="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/author_darius_foroux" android:textColor="#999999" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="148dp"
                            app:cardCornerRadius="8dp" app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="#3A5FA0" android:gravity="center" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/book_dac_nhan_tam" android:textColor="#FFFFFF"
                                    android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/book_dac_nhan_tam_title" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:maxLines="2" android:layout_marginTop="6dp"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="@string/author_dale_carnegie" android:textColor="#999999" android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSeeAll"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="@string/see_all"
                    android:textColor="#E84B3A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFFFFF"
                    app:strokeColor="#E84B3A"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp"
                    app:elevation="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp"
                android:background="#F5F4FA"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:id="@+id/navSach"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_agenda" app:tint="#E84B3A"
                    android:contentDescription="@string/nav_books"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_books" android:textColor="#E84B3A"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:id="@+id/navPodCourse"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_podcourse"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_podcourse" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:id="@+id/navKhamPha"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_search" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_explore"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_explore" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:id="@+id/navThuThach"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_share" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_challenges"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_challenges" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:id="@+id/navThuVien"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_library"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
