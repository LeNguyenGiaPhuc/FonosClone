<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- MAIN AREA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:orientation="vertical">

        <!-- FIXED HEADER + SEARCH -->
        <LinearLayout
            android:id="@+id/headerSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="18dp">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/explore_title"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/circle_white"
                    android:contentDescription="@string/avatar"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#9AAABB" />
            </LinearLayout>

            <!-- Search box -->
            <LinearLayout
                android:id="@+id/searchBox"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/card_white_round"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/search_icon_desc"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#1A2B5F" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:inputType="text"
                    android:singleLine="true"
                    android:textColor="#1A2B5F"
                    android:textColorHint="#8F9BB3"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- SCROLLABLE CONTENT ONLY -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp">

                <!-- WHITE MAIN CARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_white_round"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Dynamic Results (Hidden by default) -->
                    <LinearLayout
                        android:id="@+id/resultsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="12dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBackToCategories"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="← Quay lại"
                                android:textColor="#F07830"
                                android:textSize="14sp"
                                android:textAllCaps="false"/>

                            <TextView
                                android:id="@+id/tvResultsTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Thể loại: Văn học"
                                android:textColor="#1A2B5F"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/searchBookListContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <!-- Default Main Content Container (Promo + Categories) -->
                    <LinearLayout
                        android:id="@+id/defaultSearchContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <!-- Promo card -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="#1A2B5F"
                                    android:orientation="vertical"
                                    android:padding="20dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/search_promo_title"
                                        android:textColor="#FFFFFF"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:lineSpacingExtra="3dp"
                                        android:text="@string/search_promo_subtitle"
                                        android:textColor="#D6DDFE"
                                        android:textSize="15sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="18dp"
                                        android:text="Khám phá các thể loại giống mydio.vn"
                                        android:textColor="#F07830"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="84dp"
                                    android:layout_height="84dp"
                                    android:layout_gravity="bottom|end"
                                    android:layout_marginEnd="18dp"
                                    android:layout_marginBottom="12dp"
                                    android:alpha="0.25"
                                    android:src="@android:drawable/ic_media_play"
                                    app:tint="#FFFFFF" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Category grid -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">

                            <!-- Row 1 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:baselineAligned="false"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardVanHoc"
                                    android:layout_width="0dp"
                                    android:layout_height="120dp"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:clickable="true"
                                    android:focusable="true"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#7A4A2E">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="14dp"
                                            android:text="Văn học &amp; Truyện"
                                            android:textColor="#FFFFFF"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:layout_width="38dp"
                                            android:layout_height="38dp"
                                            android:layout_gravity="bottom|start"
                                            android:layout_marginStart="14dp"
                                            android:layout_marginBottom="14dp"
                                            android:src="@android:drawable/ic_media_play"
                                            app:tint="#CCFFFFFF" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardKyNang"
                                    android:layout_width="0dp"
                                    android:layout_height="120dp"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:clickable="true"
                                    android:focusable="true"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#4B3B96">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="14dp"
                                            android:text="Kỹ năng sống"
                                            android:textColor="#FFFFFF"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:layout_width="38dp"
                                            android:layout_height="38dp"
                                            android:layout_gravity="bottom|start"
                                            android:layout_marginStart="14dp"
                                            android:layout_marginBottom="14dp"
                                            android:src="@android:drawable/ic_menu_upload"
                                            app:tint="#CCFFFFFF" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>

                            <!-- Row 2 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:baselineAligned="false"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardKinhDoanh"
                                    android:layout_width="0dp"
                                    android:layout_height="120dp"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:clickable="true"
                                    android:focusable="true"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#3E7B3C">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="14dp"
                                            android:text="Kinh doanh"
                                            android:textColor="#FFFFFF"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:layout_width="38dp"
                                            android:layout_height="38dp"
                                            android:layout_gravity="bottom|start"
                                            android:layout_marginStart="14dp"
                                            android:layout_marginBottom="14dp"
                                            android:src="@android:drawable/ic_menu_agenda"
                                            app:tint="#CCFFFFFF" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardThieuNhi"
                                    android:layout_width="0dp"
                                    android:layout_height="120dp"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:clickable="true"
                                    android:focusable="true"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#A7444C">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="14dp"
                                            android:text="Thiếu nhi"
                                            android:textColor="#FFFFFF"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:layout_width="38dp"
                                            android:layout_height="38dp"
                                            android:layout_gravity="bottom|start"
                                            android:layout_marginStart="14dp"
                                            android:layout_marginBottom="14dp"
                                            android:src="@android:drawable/ic_menu_gallery"
                                            app:tint="#CCFFFFFF" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>

                            <!-- Row 3 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:baselineAligned="false"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardTamLy"
                                    android:layout_width="0dp"
                                    android:layout_height="120dp"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:clickable="true"
                                    android:focusable="true"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#946B00">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="14dp"
                                            android:text="Tâm lý học"
                                            android:textColor="#FFFFFF"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:layout_width="38dp"
                                            android:layout_height="38dp"
                                            android:layout_gravity="bottom|start"
                                            android:layout_marginStart="14dp"
                                            android:layout_marginBottom="14dp"
                                            android:src="@android:drawable/ic_menu_edit"
                                            app:tint="#CCFFFFFF" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardTamLinh"
                                    android:layout_width="0dp"
                                    android:layout_height="120dp"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:clickable="true"
                                    android:focusable="true"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <FrameLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#2D8C92">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="14dp"
                                            android:text="Tâm linh"
                                            android:textColor="#FFFFFF"
                                            android:textSize="16sp"
                                            android:textStyle="bold" />

                                        <ImageView
                                            android:layout_width="38dp"
                                            android:layout_height="38dp"
                                            android:layout_gravity="bottom|start"
                                            android:layout_marginStart="14dp"
                                            android:layout_marginBottom="14dp"
                                            android:src="@android:drawable/ic_menu_compass"
                                            app:tint="#CCFFFFFF" />
                                    </FrameLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- BOTTOM NAVIGATION -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
