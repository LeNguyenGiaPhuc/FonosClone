<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF0EE">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="#FDF0EE">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#F07030"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#FFFFFF"
                            android:padding="9dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="@string/app_name"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name_lowercase"
                        android:textSize="21sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpgrade"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="@string/upgrade"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#F07030"
                    app:cornerRadius="19dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="10dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ivAvatar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    app:cardCornerRadius="19dp"
                    app:cardBackgroundColor="#E0DADA"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#AAAAAA"
                        android:padding="7dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/avatar"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#5A3580">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/did_you_know"
                        android:textColor="#DDBBFF"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/podcourse_banner_line1"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:lineSpacingMultiplier="1.3"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="2dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/podcourse_banner_line2_highlight"
                                    android:textColor="#F5A030"
                                    android:textSize="15sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/podcourse_banner_line2_rest"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/arrow_right"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            app:cardCornerRadius="3.5dp"
                            app:cardBackgroundColor="#AA88CC"
                            app:cardElevation="0dp"
                            android:layout_marginEnd="5dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            app:cardCornerRadius="3.5dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardElevation="0dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/podcourse_free_header"
                        android:textColor="#8060A0"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/for_members_only"
                        android:textColor="#1A1A2E"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all_arrow"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAI"
                        android:layout_width="260dp"
                        android:layout_height="380dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="#1A6B6B"
                                android:gravity="bottom">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:background="#1E8080"
                                    android:gravity="center">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/emoji_user"
                                        android:textSize="72sp"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:background="#CC000000"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/podcourse_ai_title"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:lineSpacingMultiplier="1.25"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/author_nam_nguyen"
                                        android:textColor="#CCCCCC"
                                        android:textSize="13sp"
                                        android:layout_marginTop="5dp"/>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:layout_marginTop="8dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/rating_ai"
                                            android:textColor="#F5C518"
                                            android:textSize="12sp"/>

                                        <View android:layout_width="0dp"
                                            android:layout_height="1dp" android:layout_weight="1"/>

                                        <com.google.android.material.card.MaterialCardView
                                            android:layout_width="wrap_content"
                                            android:layout_height="24dp"
                                            app:cardCornerRadius="12dp"
                                            app:cardBackgroundColor="#8B5CF6"
                                            app:cardElevation="0dp">
                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="match_parent"
                                                android:text="@string/member_badge"
                                                android:textColor="#FFFFFF"
                                                android:textSize="11sp"
                                                android:textStyle="bold"
                                                android:gravity="center"/>
                                        </com.google.android.material.card.MaterialCardView>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:layout_gravity="center"
                                android:layout_marginBottom="100dp"
                                app:cardCornerRadius="26dp"
                                app:cardBackgroundColor="#AAFFFFFF"
                                app:cardElevation="4dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@android:drawable/ic_media_play"
                                    app:tint="#FFFFFF"
                                    android:padding="12dp"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/play"/>
                            </com.google.android.material.card.MaterialCardView>

                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardManage"
                        android:layout_width="260dp"
                        android:layout_height="380dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="#3D3530"
                                android:gravity="bottom">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:background="#7A5540"
                                    android:gravity="center">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/emoji_user"
                                        android:textSize="72sp"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:background="#CC000000"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/podcourse_manage_title"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:lineSpacingMultiplier="1.25"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/author_vu_duc_tri_the"
                                        android:textColor="#CCCCCC"
                                        android:textSize="13sp"
                                        android:layout_marginTop="5dp"/>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:layout_marginTop="8dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/rating_manage"
                                            android:textColor="#F5C518"
                                            android:textSize="12sp"/>

                                        <View android:layout_width="0dp"
                                            android:layout_height="1dp" android:layout_weight="1"/>

                                        <com.google.android.material.card.MaterialCardView
                                            android:layout_width="wrap_content"
                                            android:layout_height="24dp"
                                            app:cardCornerRadius="12dp"
                                            app:cardBackgroundColor="#8B5CF6"
                                            app:cardElevation="0dp">
                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="match_parent"
                                                android:text="@string/member_badge"
                                                android:textColor="#FFFFFF"
                                                android:textSize="11sp"
                                                android:textStyle="bold"
                                                android:gravity="center"/>
                                        </com.google.android.material.card.MaterialCardView>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:layout_gravity="center"
                                android:layout_marginBottom="100dp"
                                app:cardCornerRadius="26dp"
                                app:cardBackgroundColor="#AAFFFFFF"
                                app:cardElevation="4dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@android:drawable/ic_media_play"
                                    app:tint="#FFFFFF"
                                    android:padding="12dp"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/play"/>
                            </com.google.android.material.card.MaterialCardView>

                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFinance"
                        android:layout_width="260dp"
                        android:layout_height="380dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="#1A3A5C"
                                android:gravity="bottom">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:background="#2A5080"
                                    android:gravity="center">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/emoji_user"
                                        android:textSize="72sp"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:background="#CC000000"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/podcourse_finance_title"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:lineSpacingMultiplier="1.25"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/author_tran_viet_quan"
                                        android:textColor="#CCCCCC"
                                        android:textSize="13sp"
                                        android:layout_marginTop="5dp"/>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:layout_marginTop="8dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/rating_finance"
                                            android:textColor="#F5C518"
                                            android:textSize="12sp"/>

                                        <View android:layout_width="0dp"
                                            android:layout_height="1dp" android:layout_weight="1"/>

                                        <com.google.android.material.card.MaterialCardView
                                            android:layout_width="wrap_content"
                                            android:layout_height="24dp"
                                            app:cardCornerRadius="12dp"
                                            app:cardBackgroundColor="#8B5CF6"
                                            app:cardElevation="0dp">
                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="match_parent"
                                                android:text="@string/member_badge"
                                                android:textColor="#FFFFFF"
                                                android:textSize="11sp"
                                                android:textStyle="bold"
                                                android:gravity="center"/>
                                        </com.google.android.material.card.MaterialCardView>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:layout_gravity="center"
                                android:layout_marginBottom="100dp"
                                app:cardCornerRadius="26dp"
                                app:cardBackgroundColor="#AAFFFFFF"
                                app:cardElevation="4dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@android:drawable/ic_media_play"
                                    app:tint="#FFFFFF"
                                    android:padding="12dp"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/play"/>
                            </com.google.android.material.card.MaterialCardView>

                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/most_listened"
                        android:textColor="#8060A0"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/featured_courses"
                        android:textColor="#1A1A2E"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all_arrow"
                    android:textColor="#1A1A2E"
                    android:textSize="26sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#1E8080"
                            app:cardElevation="0dp">
                            <TextView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/emoji_grad" android:textSize="24sp"
                                android:gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/podcourse_ai_short"
                                android:textColor="#1A1A2E"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/author_nam_nguyen_rating"
                                android:textColor="#999999"
                                android:textSize="11sp"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#E84B3A"
                            android:contentDescription="@string/play"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#7A5540"
                            app:cardElevation="0dp">
                            <TextView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/emoji_chart" android:textSize="24sp"
                                android:gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/podcourse_manage_short"
                                android:textColor="#1A1A2E"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/author_vu_duc_tri_the_rating"
                                android:textColor="#999999"
                                android:textSize="11sp"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#E84B3A"
                            android:contentDescription="@string/play"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="#2A5080"
                            app:cardElevation="0dp">
                            <TextView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/emoji_money" android:textSize="24sp"
                                android:gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/podcourse_finance_short"
                                android:textColor="#1A1A2E"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/author_tran_viet_quan_rating"
                                android:textColor="#999999"
                                android:textSize="11sp"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#E84B3A"
                            android:contentDescription="@string/play"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navSach" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_agenda" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_books"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_books" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navPodCourse" android:clickable="true" android:focusable="true">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp" android:layout_height="26dp"
                    app:cardCornerRadius="6dp" app:cardBackgroundColor="#F07030"
                    app:cardElevation="0dp">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                        android:src="@android:drawable/ic_media_play" app:tint="#FFFFFF"
                        android:padding="4dp" android:scaleType="fitCenter"
                        android:contentDescription="@string/nav_podcourse"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_podcourse" android:textColor="#F07030"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navKhamPha" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_search" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_explore"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_explore" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navThuThach" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_share" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_challenges"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_challenges" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navThuVien" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#AAAAAA"
                    android:contentDescription="@string/nav_library"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_library" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
