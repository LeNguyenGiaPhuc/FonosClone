<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════╗
    ║  activity_khampha.xml — Fonos "Khám phá" Screen     ║
    ║  ✅ 1 file duy nhất — không cần drawable XML nào     ║
    ║  Requires: Material Components 1.11.0                ║
    ╚══════════════════════════════════════════════════════╝
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ════════════════════════════════════════
         HEADER — blue background
    ════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#3D5A8A"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="28dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Khám phá"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <!-- Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#C8D0DC"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#888888"
                    android:padding="7dp"
                    android:scaleType="fitCenter"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Search bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:tint="#AAAAAA"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Tìm tên sách, tác giả, mentor..."
                    android:textColorHint="#BBBBBB"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:paddingLeft="10dp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ════════════════════════════════════════
         WHITE ROUNDED BODY — bo góc trên
    ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="-20dp"
        android:overScrollMode="never">

        <!-- White container with top rounded corners -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F4F2FA"
            android:paddingTop="8dp"
            android:paddingBottom="80dp">

            <!-- Thin top visual rounded edge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="0dp"
                android:layout_marginRight="0dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#F4F2FA"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:paddingTop="14dp">

                    <!-- ════════════════════════════════
                         BANNER: PodCourse – Cập Nhật Mới
                    ════════════════════════════════ -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/bannerPodCourse"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#2B2B2B"
                        android:layout_marginBottom="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- Left: text content -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PodCourse – Cập Nhật Mới"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="220dp"
                                    android:layout_height="wrap_content"
                                    android:text="Hội viên giờ đây có thể xem miễn phí hơn 30 PodCourse trên Fonos!"
                                    android:textColor="#BBBBBB"
                                    android:textSize="12sp"
                                    android:lineSpacingMultiplier="1.3"
                                    android:layout_marginTop="6dp"/>

                                <!-- Logo row -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="12dp">

                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        app:cardCornerRadius="6dp"
                                        app:cardBackgroundColor="#F07030"
                                        app:cardElevation="0dp">
                                        <ImageView android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:src="@android:drawable/ic_media_play"
                                            android:tint="#FFFFFF" android:padding="5dp"
                                            android:scaleType="fitCenter"/>
                                    </com.google.android.material.card.MaterialCardView>

                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="  ×  " android:textColor="#AAAAAA"
                                        android:textSize="14sp"/>

                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        app:cardCornerRadius="6dp"
                                        app:cardBackgroundColor="#444444"
                                        app:cardElevation="0dp">
                                        <ImageView android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:src="@android:drawable/ic_media_play"
                                            android:tint="#CCCCCC" android:padding="5dp"
                                            android:scaleType="fitCenter"/>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Right: avatar images stack -->
                            <LinearLayout
                                android:layout_width="120dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="right"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:padding="8dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="55dp"
                                    android:layout_height="100dp"
                                    app:cardCornerRadius="10dp"
                                    app:cardBackgroundColor="#5577AA"
                                    app:cardElevation="2dp"
                                    android:layout_marginEnd="4dp">
                                    <TextView android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="👩‍🏫" android:textSize="30sp"
                                        android:gravity="center"/>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="55dp"
                                    android:layout_height="100dp"
                                    app:cardCornerRadius="10dp"
                                    app:cardBackgroundColor="#AA8855"
                                    app:cardElevation="2dp">
                                    <TextView android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="👨‍💼" android:textSize="30sp"
                                        android:gravity="center"/>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>

                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ════════════════════════════════
                         CATEGORY GRID 2×N
                    ════════════════════════════════ -->

                    <!-- Row 1: Sách Nói | Sách Tiếng Anh -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <!-- Sách Nói -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catSachNoi"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#7A4520"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Sách Nói"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp"
                                        android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🎧"
                                        android:textSize="22sp"/>
                                </LinearLayout>

                                <!-- Book thumbnail right -->
                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical"
                                    android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp"
                                        android:layout_height="78dp"
                                        app:cardCornerRadius="6dp"
                                        app:cardBackgroundColor="#EEEEEE"
                                        app:cardElevation="3dp">
                                        <LinearLayout android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#D4A870"
                                            android:gravity="center" android:padding="4dp">
                                            <TextView android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="Sapiens" android:textColor="#4A2000"
                                                android:textSize="8sp" android:textStyle="bold"
                                                android:gravity="center"/>
                                        </LinearLayout>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Sách Tiếng Anh -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catSachAnh"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#2E2E7A"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Sách Tiếng Anh"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp"
                                        android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🎧"
                                        android:textSize="22sp"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical"
                                    android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp"
                                        android:layout_height="78dp"
                                        app:cardCornerRadius="6dp"
                                        app:cardBackgroundColor="#CCDDEE"
                                        app:cardElevation="3dp">
                                        <LinearLayout android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#AABBCC"
                                            android:gravity="center" android:padding="4dp">
                                            <TextView android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="Call of\nWild" android:textColor="#112244"
                                                android:textSize="8sp" android:textStyle="bold"
                                                android:gravity="center"/>
                                        </LinearLayout>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 2: Ebook | Tóm Tắt Sách -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <!-- Ebook -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catEbook"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#2A6040"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Ebook"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp"
                                        android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="☰"
                                        android:textSize="22sp"
                                        android:textColor="#FFFFFF"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical"
                                    android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp"
                                        android:layout_height="78dp"
                                        app:cardCornerRadius="6dp"
                                        app:cardBackgroundColor="#88BB88"
                                        app:cardElevation="3dp">
                                        <LinearLayout android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#5A9060"
                                            android:gravity="center" android:padding="4dp">
                                            <TextView android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="Thiều\nvề\ntrái tim" android:textColor="#EEFFEE"
                                                android:textSize="7sp" android:textStyle="bold"
                                                android:gravity="center"/>
                                        </LinearLayout>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Tóm Tắt Sách -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catTomTat"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#8A6A20"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Tóm Tắt Sách"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp"
                                        android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📋"
                                        android:textSize="22sp"/>
                                </LinearLayout>

                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical"
                                    android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp"
                                        android:layout_height="78dp"
                                        app:cardCornerRadius="6dp"
                                        app:cardBackgroundColor="#EE4444"
                                        app:cardElevation="3dp">
                                        <LinearLayout android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#CC2222"
                                            android:gravity="center" android:padding="4dp">
                                            <TextView android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="Ai lấy\nPho mát\ncủa tôi" android:textColor="#FFFFFF"
                                                android:textSize="7sp" android:textStyle="bold"
                                                android:gravity="center"/>
                                        </LinearLayout>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 3: Thiếu Nhi | Thiền -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <!-- Thiếu Nhi -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catThieuNhi"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#8A3030"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical" android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Thiếu Nhi"
                                        android:textColor="#FFFFFF" android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp" android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🧸" android:textSize="22sp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical" android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp" android:layout_height="78dp"
                                        app:cardCornerRadius="6dp" app:cardBackgroundColor="#FFCCAA"
                                        app:cardElevation="3dp">
                                        <TextView android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:text="👧" android:textSize="28sp"
                                            android:gravity="center"/>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Thiền -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catThien"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#3A6A7A"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical" android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Thiền"
                                        android:textColor="#FFFFFF" android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp" android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🔷" android:textSize="22sp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical" android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp" android:layout_height="78dp"
                                        app:cardCornerRadius="6dp" app:cardBackgroundColor="#7ABAAA"
                                        app:cardElevation="3dp">
                                        <TextView android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:text="🌿" android:textSize="28sp"
                                            android:gravity="center"/>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 4: Truyện Ngủ & Nhạc | Podcast -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <!-- Truyện Ngủ & Nhạc -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catTruyenNgu"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#3A2A7A"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical" android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Truyện Ngủ\n&amp; Nhạc"
                                        android:textColor="#FFFFFF" android:textSize="15sp"
                                        android:textStyle="bold" android:lineSpacingMultiplier="1.2"/>
                                    <View android:layout_width="0dp" android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🎵" android:textSize="22sp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical" android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp" android:layout_height="78dp"
                                        app:cardCornerRadius="6dp" app:cardBackgroundColor="#1A1A4A"
                                        app:cardElevation="3dp">
                                        <TextView android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:text="🌌" android:textSize="28sp"
                                            android:gravity="center"/>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Podcast -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/catPodcast"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#1A7A3A"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <LinearLayout android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical" android:padding="14dp">
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Podcast"
                                        android:textColor="#FFFFFF" android:textSize="15sp"
                                        android:textStyle="bold"/>
                                    <View android:layout_width="0dp" android:layout_height="0dp"
                                        android:layout_weight="1"/>
                                    <TextView android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🎙️" android:textSize="22sp"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="right|center_vertical"
                                    android:gravity="center_vertical" android:paddingRight="8dp">
                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="54dp" android:layout_height="78dp"
                                        app:cardCornerRadius="6dp" app:cardBackgroundColor="#44EE88"
                                        app:cardElevation="3dp">
                                        <LinearLayout android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#22CC66"
                                            android:gravity="center" android:padding="4dp">
                                            <TextView android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="HAVE\nA\nSIP" android:textColor="#003311"
                                                android:textSize="9sp" android:textStyle="bold"
                                                android:gravity="center"/>
                                        </LinearLayout>
                                    </com.google.android.material.card.MaterialCardView>
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════
         BOTTOM NAVIGATION
    ════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Sách -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navSach" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_agenda" android:tint="#AAAAAA"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sách" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- PodCourse -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navPodCourse" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play" android:tint="#AAAAAA"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PodCourse" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Khám phá (active) -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navKhamPha" android:clickable="true" android:focusable="true">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="28dp" android:layout_height="28dp"
                    app:cardCornerRadius="14dp" app:cardBackgroundColor="#FFF0E8"
                    app:cardElevation="0dp">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_search" android:tint="#F07030"
                        android:padding="4dp" android:scaleType="fitCenter"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Khám phá" android:textColor="#F07030"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Thử thách -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navThuThach" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_share" android:tint="#AAAAAA"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Thử thách" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Thư viện -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navThuVien" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size" android:tint="#AAAAAA"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Thư viện" android:textColor="#AAAAAA"
                    android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>